# ==============================================
# JWT 认证配置
# ==============================================
# JWT签名密钥（必须设置，建议使用至少32位的随机字符串）
# 生成方式：python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY="CHANGE_ME_IN_PRODUCTION"

# JWT签名算法（默认HS256，一般不需要修改）
JWT_ALGORITHM="HS256"

# 访问令牌有效期（分钟），默认15分钟
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15

# 刷新令牌有效期（天），默认7天
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ==============================================
# LLM 大模型配置
# ==============================================
# LLM类型：ALIYUN(阿里云百炼) | OLLAMA(本地模型)
LLM_TYPE="ALIYUN"

# ==============================================
# Ollama 配置（仅 LLM_TYPE=OLLAMA 时生效）
# ==============================================
# Ollama 服务地址（本地运行Ollama时，默认为该地址）
OLLAMA_BASE_URL="http://localhost:11434"
# Ollama 聊天模型（需提前 ollama pull 下载）
OLLAMA_MODEL_NAME="qwen3.5:0.8b"


# ==============================================
# 阿里云百炼配置（仅 LLM_TYPE=ALIYUN 时生效）
# ==============================================
# 阿里云百炼 API 密钥
ALIYUN_ACCESS_KEY_SECRET="your_api_key"
ALIYUN_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"
ALIYUN_MODEL_NAME="qwen3-max"

# ==============================================
# Embedding 模型配置
# ==============================================
# Embedding 模型类型：ALIYUN(阿里云百炼) | OLLAMA(本地模型)
EMBED_MODEL_TYPE="ALIYUN"

# ==============================================
# Ollama Embedding 配置（仅 EMBED_MODEL_TYPE=OLLAMA 时生效）
# ==============================================
OLLAMA_EMBED_MODEL_NAME="qwen3-embedding:0.6b"

# ==============================================
# 阿里云百炼 Embedding 配置（仅 EMBED_MODEL_TYPE=ALIYUN 时生效）
# ==============================================
ALIYUN_EMBED_MODEL_NAME="text-embedding-v4"

# ==============================================
# Re-ranker 重排序模型配置
# ==============================================
# 重排序模型本地路径（不配置则自动跳过重排序，不影响检索结果）
RERANKER_MODEL_PATH="./data/models/Qwen/Qwen3-Reranker-0.6B"
RERANKER_MODEL_NAME="Qwen/Qwen3-Reranker-0.6B"
RERANKER_MODEL_DIR="./data/models/"

# ==============================================
# 日志配置
# ==============================================
# 全局日志级别：DEBUG | INFO | WARNING | ERROR（默认 INFO）
LOG_LEVEL="INFO"
# 按模块设置日志级别（逗号分隔），格式：模块名=级别,模块名=级别
# 示例：LOG_LEVEL_MODULES=LLMGateway=DEBUG,Orchestrator=DEBUG
LOG_LEVEL_MODULES="LLMGateway=DEBUG,Orchestrator=DEBUG"

